          "Block Reality/api/src/main/java/com/blockreality/api/node/NodeGraph.java",
          "Block Reality/api/src/main/java/com/blockreality/api/node/EvaluateScheduler.java",
          "Block Reality/fastdesign/src/main/java/com/blockreality/fastdesign/client/node/BRNode.java",
          "Block Reality/fastdesign/src/main/java/com/blockreality/fastdesign/client/node/binding/MaterialBinder.java",
          "Block Reality/api/src/main/java/com/blockreality/api/node/NodeGraphIO.java"
        ]
      }
    },
    {
      "id": "dataflow:fluid-coupling",
      "title": "流體-結構耦合資料流",
      "type": "dataflow",
      "tags": ["dataflow", "fluid", "physics", "coupling"],
      "content": "BRConfig.isFluidEnabled() == true → FluidRegionRegistry 掃描水域 → FluidGPUEngine / FluidAsyncCompute 執行 Jacobi 壓力求解（fluid_jacobi.comp.glsl）→ FluidPressureCoupler 將流體壓力轉換為結構荷載 → FluidStructureCoupler 延遲 1 tick 將荷載注入到 PFSF source buffer → PFSFEngine 計算結構應力 → 若結構破壞導致流體屏障失效，觸發 FluidBarrierBreachEvent。",
      "metadata": {
        "stages": [
          "FluidRegionRegistry",
          "FluidGPUEngine",
          "fluid_jacobi.comp.glsl",
          "FluidPressureCoupler",
          "FluidStructureCoupler",
          "PFSFEngine",
          "FluidBarrierBreachEvent"
        ],
        "note": "流體系統預設關閉，且流體-結構耦合有 1 tick 延遲（設計如此）",
        "related_files": [
          "Block Reality/api/src/main/java/com/blockreality/api/physics/fluid/FluidRegionRegistry.java",
          "Block Reality/api/src/main/java/com/blockreality/api/physics/fluid/FluidGPUEngine.java",
          "Block Reality/api/src/main/java/com/blockreality/api/physics/fluid/FluidStructureCoupler.java",
          "Block Reality/api/src/main/java/com/blockreality/api/physics/fluid/FluidPressureCoupler.java",
          "Block Reality/api/src/main/java/com/blockreality/api/event/FluidBarrierBreachEvent.java"
        ]
      }
    }
