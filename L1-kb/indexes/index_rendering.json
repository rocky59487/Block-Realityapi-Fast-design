        ]
      }
    },
    {
      "id": "render:denoiser",
      "title": "降噪器（ReLAX / NRD / SVGF）",
      "type": "render",
      "tags": ["render", "denoiser", "vulkan", "rt", "client-only"],
      "content": "支援多種降噪器：BRReLAXDenoiser（NVIDIA ReLAX）、BRNRDNative（NRD JNI 橋接）、BRSVGFDenoiser（SVGF）。NRD JNI 橋接位於 api/src/main/native/，需獨立 cmake 建置。",
      "metadata": {
        "related_files": [
          "Block Reality/api/src/main/java/com/blockreality/api/client/render/rt/BRReLAXDenoiser.java",
